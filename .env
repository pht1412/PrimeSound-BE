PORT=5000
# JWT secret - thay đổi trong production!
JWT_SECRET=primesound-secret-key-change-in-production
# Nếu em dùng MongoDB cài trên máy cá nhân:
MONGO_URI=mongodb://localhost:27017/primesound_db
# Nếu em dùng MongoDB Atlas (Cloud), hãy thay bằng chuỗi kết nối của họ.

# MOCK_NOTIFICATION=true: Cho phép gọi API giả lập (Dùng khi dev/test độc lập)
# MOCK_NOTIFICATION=false: Khóa API giả lập (Dùng khi đã merge với các module khác)
MOCK_NOTIFICATION=false

# MOCK_FOLLOWERS=true: Bật giả lập người theo dõi khi có bài hát mới
MOCK_FOLLOWERS=false
# Điền 1 ID User bất kỳ (khác ID của người upload) vào đây để hứng thông báo test
#TEST_FOLLOWER_ID="69c0bbbe51ca1a4fa14b2266"

