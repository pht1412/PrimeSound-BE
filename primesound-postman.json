{
  "info": {
    "name": "PrimeSound API Testing",
    "_postman_id": "12345678-abcd-efgh-ijkl-1234567890ab",
    "description": "Test toàn bộ API PrimeSound",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "description": "Server chạy ở PORT 5000 (xem .env)"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/"
      }
    },
    {
      "name": "2. Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Phat\",\n  \"email\": \"phat123@gmail.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{base_url}}/api/v1/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  var json = pm.response.json();",
              "  if (json.token && json.user) {",
              "    pm.collectionVariables.set('token', json.token);",
              "    pm.collectionVariables.set('user_id', json.user._id);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"phat123@gmail.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{base_url}}/api/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);",
              "pm.collectionVariables.set('user_id', json.user._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Get Me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/api/v1/users/me"
      }
    },
    {
      "name": "5. Update Profile",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Phat Updated", "type": "text" },
            { "key": "avatar", "type": "file", "src": "" }
          ]
        },
        "url": "{{base_url}}/api/v1/users/me"
      }
    },
    {
      "name": "6. Change Password",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"1234567\"\n}"
        },
        "url": "{{base_url}}/api/v1/users/me/password"
      }
    },
    {
      "name": "7. Create Song",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "Test Song", "type": "text" },
            { "key": "genre", "value": "Pop", "type": "text" },
            { "key": "audio", "type": "file", "src": "" },
            { "key": "cover", "type": "file", "src": "" }
          ]
        },
        "url": "{{base_url}}/api/v1/songs"
      }
    },
    {
      "name": "8. Get All Songs",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/songs"
      }
    },
    {
      "name": "9. Search Songs",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/v1/search?keyword=test"
      }
    },
    {
      "name": "10. Create Playlist",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"My Playlist\"\n}"
        },
        "url": "{{base_url}}/api/v1/playlists"
      }
    },
    {
      "name": "11. Get Playlists",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/api/v1/playlists"
      }
    }
  ]
}